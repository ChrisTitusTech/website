# Authentik environment variables
# Copy this file to .env and fill in all values before running docker compose up

# ---------------------------------------------------------------------------
# Postgres
# ---------------------------------------------------------------------------
PG_PASS=change_me_strong_db_password
PG_USER=authentik
PG_DB=authentik

# ---------------------------------------------------------------------------
# Authentik core
# ---------------------------------------------------------------------------
AUTHENTIK_SECRET_KEY=change_me_50_char_random_secret_key_here_xxxxxxxx
AUTHENTIK_ERROR_REPORTING__ENABLED=false

# ---------------------------------------------------------------------------
# SMTP via Amazon SES (us-east-1 shown — change region slug if needed)
#
# 1. In AWS Console → SES → SMTP Settings → "Create SMTP credentials"
#    This creates an IAM user and generates SMTP-specific credentials
#    (NOT your regular AWS Access Key — they are different).
#
# 2. The SMTP username/password shown after creation are the values below.
#    You cannot retrieve the password again after closing that dialog.
#
# 3. Your FROM address must be verified in SES:
#    SES → Verified identities → Create identity → Email address
#    If your account is still in the SES sandbox, you must also verify
#    every recipient address. Request production access to remove that limit.
#
# SES SMTP endpoints by region:
#   us-east-1      email-smtp.us-east-1.amazonaws.com
#   us-west-2      email-smtp.us-west-2.amazonaws.com
#   eu-west-1      email-smtp.eu-west-1.amazonaws.com
#   ap-southeast-2 email-smtp.ap-southeast-2.amazonaws.com
# ---------------------------------------------------------------------------
AUTHENTIK_EMAIL__HOST=email-smtp.us-east-1.amazonaws.com
AUTHENTIK_EMAIL__PORT=2587 #most VPS providers block outbound traffic on port 25, so use the alternate SMTP port 2587 for SES instead
AUTHENTIK_EMAIL__USERNAME=AKIAIOSFODNN7EXAMPLE        # SES SMTP username (looks like an Access Key ID)
AUTHENTIK_EMAIL__PASSWORD=your_ses_smtp_password_here # SES SMTP password (base64 string, ~44 chars)
AUTHENTIK_EMAIL__USE_TLS=true                         # STARTTLS on port 587; set false and port 465 for SSL
AUTHENTIK_EMAIL__USE_SSL=false                        # set true and PORT=465 as alternative to STARTTLS
AUTHENTIK_EMAIL__TIMEOUT=10
AUTHENTIK_EMAIL__FROM=noreply@christitus.com          # must be verified in SES

# ---------------------------------------------------------------------------
# LDAP outpost token
# Create a Service Account in Authentik UI → Admin → System → Outposts,
# create an LDAP outpost, copy the token here.
# ---------------------------------------------------------------------------
AUTHENTIK_LDAP_TOKEN=paste_ldap_outpost_token_here

# ---------------------------------------------------------------------------
# Authentik image version (pin to a specific release for stability)
# ---------------------------------------------------------------------------
AUTHENTIK_TAG=2026.2.2
